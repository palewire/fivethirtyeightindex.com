{
	"ci": {
		"collect": {
			"staticDistDir": "./build",
			"url": [
				"http://localhost/index.html",
				"http://localhost/byline/index.html",
				"http://localhost/byline/nate-silver/index.html",
				"http://localhost/year/2016/index.html"
			],
			"settings": {
				"chromeFlags": "--no-sandbox --headless=new",
				"onlyCategories": [
					"performance",
					"accessibility",
					"seo"
				]
			},
			"numberOfRuns": 1
		},
		"assert": {
			"assertions": {
				"categories:performance": ["error", { "minScore": 0.6 }],
				"categories:accessibility": ["error", { "minScore": 0.95 }],
				"categories:seo": ["error", { "minScore": 0.95 }]
			}
		},
		"upload": { "target": "temporary-public-storage" }
	}
}
